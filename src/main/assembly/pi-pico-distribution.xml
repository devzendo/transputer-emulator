<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.0.0 http://maven.apache.org/xsd/assembly-2.0.0.xsd">
    <id>pi-pico</id>
    <formats>
        <format>tar.gz</format>
    </formats>
    <baseDirectory>/</baseDirectory>
    <includeBaseDirectory>true</includeBaseDirectory>

    <fileSets>
        <fileSet>
            <directory>${project.basedir}/${cmake.binary.dir}/Emulator</directory>
            <includes>
                <include>temulate.*</include>
            </includes>
            <outputDirectory>bin</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/${cmake.binary.dir}/Pico</directory>
            <includes>
                <include>picolinkadapter.*</include>
                <include>picolinkharness.*</include>
                <include>picolinkreflect.*</include>
            </includes>
            <outputDirectory>bin</outputDirectory>
        </fileSet>
    </fileSets>
    <files>
        <file>
            <source>${project.basedir}/README.md</source>
            <outputDirectory>./</outputDirectory>
            <destName>README-transputer-emulator.md</destName>
        </file>
    </files>

</assembly>